{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": [
    "eslint:recommended",
    "prettier"
  ],
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "globals": {
    "Vue": "readonly",
    "VueRouter": "readonly",
    "axios": "readonly",
    "turnstile": "readonly"
  },
  "rules": {
    "no-unused-vars": "warn"
  }
}
